# Modele de fichier d'environnement backend - Tunisys_Dab
# =========================================================
#
# A copier sur le serveur sous : backend\.env
# (chemin resolu par app/core/config.py : <racine_projet>/backend/.env)
#
# ATTENTION : ne JAMAIS committer le vrai fichier .env issu de ce modele.
# Il contient des secrets (mot de passe DB, cle JWT). Le .gitignore du
# projet ignore deja backend/.env et .env.
#
# NOTE POUR CELUI QUI DEPLOIE :
# Les noms de variables ci-dessous correspondent EXACTEMENT a ceux lus
# par backend/app/core/config.py (classe Settings, alias Pydantic). En
# cas de doute ou d'ajout d'une variable cote code, verifier ce fichier
# pour completer .env en consequence : les noms doivent correspondre au
# champ "alias=" de chaque Field, pas au nom Python de l'attribut.
# Il n'y a PAS de variable DATABASE_URL unique : la connexion PostgreSQL
# est reconstruite par le code a partir des 5 variables DB_* ci-dessous.

# --- Application ---
APP_NAME=Solution DAB API
APP_ENV=production
APP_DEBUG=false
API_PREFIX=/api

# Origines autorisees pour le CORS (liste separee par des virgules).
# En production, mettre l'URL exacte du site IIS (schema+host+port si
# non standard). Ne pas laisser localhost en production.
CORS_ORIGINS=http://NOM-OU-IP-DU-SERVEUR

# --- Base de donnees PostgreSQL ---
# Host/port/nom de base de l'instance PostgreSQL 15+ du serveur.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Tunisys_Dab
DB_USER=postgres
# Mot de passe du role PostgreSQL ci-dessus. VIDE ICI VOLONTAIREMENT :
# a renseigner uniquement dans le backend/.env reel du serveur, jamais ici.
DB_PASSWORD=

# --- Authentification JWT ---
# Cle secrete de signature des tokens JWT. VIDE ICI VOLONTAIREMENT :
# a GENERER sur le serveur (ex: python -c "import secrets; print(secrets.token_urlsafe(64))")
# et a coller uniquement dans le backend/.env reel du serveur.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Nombre de rounds bcrypt pour le hachage des mots de passe utilisateurs.
BCRYPT_ROUNDS=12

# --- Metier ---
# Seuil (montant) en dessous duquel une alerte de coffre est declenchee.
SEUIL_ALERTE_COFFRE=5000

# Active/desactive la collecte automatique planifiee (APScheduler, tous
# les jours a 02:00). Mettre a true uniquement quand la collecte SSH vers
# les DAB est correctement configuree et testee.
COLLECTE_AUTO_ENABLED=false
