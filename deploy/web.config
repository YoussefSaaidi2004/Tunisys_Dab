<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config - Configuration IIS pour Tunisys_Dab (deploiement HTTP)
  ===================================================================

  A placer a la RACINE du site IIS, c'est-a-dire dans le dossier servi
  par IIS : frontend\dist (le build React statique).

  Prerequis obligatoires sur le serveur IIS :
    1. Module "URL Rewrite" installe (IIS URL Rewrite Module 2.1+).
    2. Module "Application Request Routing" (ARR) installe.
    3. Le proxy ARR doit etre ACTIVE au niveau du serveur IIS :
       IIS Manager > (noeud serveur, pas le site) > Application Request
       Routing Cache > Server Proxy Settings... > cocher "Enable proxy".
       Sans cette case cochee, toute regle de reverse-proxy ci-dessous
       echoue silencieusement (souvent en 502, parfois en 404).

  Deploiement en HTTP uniquement : aucune redirection HTTP->HTTPS,
  aucun binding SSL, aucune section HTTPS ici (voir CHECKLIST_DEPLOIEMENT.md
  pour la note sur une eventuelle mise en HTTPS future).

  IMPORTANT - ORDRE DES REGLES :
  La regle de reverse-proxy "/api" DOIT etre evaluee AVANT la regle de
  fallback SPA. Si l'ordre est inverse, les appels /api/* seraient
  intercepts par le fallback et renverraient index.html au lieu du JSON
  attendu par le frontend.
-->
<configuration>
  <system.webServer>

    <!-- Necessaire pour que les modules JS/CSS/etc. du build Vite soient
         servis avec le bon type MIME (evite les soucis de cache/mime sur
         certaines configs IIS par defaut). -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <rewrite>
      <rules>

        <!-- =============================================================
             REGLE 1 (PREMIERE) : Reverse-proxy vers l'API FastAPI/Uvicorn
             Reecrit toute requete /api/... vers http://127.0.0.1:8000/api/...
             action type="Rewrite" (et non "Redirect") : IIS effectue lui-meme
             la requete vers Uvicorn et renvoie la reponse au navigateur,
             sans que celui-ci ne voie ni ne suive de redirection.
             ============================================================= -->
        <rule name="ReverseProxyToBackend" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/api/{R:1}" logRewrittenUrl="true" />
        </rule>

        <!-- =============================================================
             REGLE 2 (APRES la regle API) : Fallback SPA React Router
             Si l'URL demandee ne correspond ni a un fichier existant
             (IsFile) ni a un dossier existant (IsDirectory), et qu'elle ne
             commence PAS par "api/", on reecrit vers /index.html afin que
             React Router puisse gerer la route cote client (ex: F5 sur
             /dashboard/collecte).
             ============================================================= -->
        <rule name="SpaFallbackReactRouter" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <!-- Ne jamais intercepter les appels API : ils sont deja geres
                 par la regle ci-dessus et stoppes via stopProcessing. Cette
                 exclusion est une securite supplementaire. -->
            <add input="{URL}" pattern="^/?api/" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>

      </rules>
    </rewrite>

  </system.webServer>
</configuration>
