APP_NAME=Solution DAB API
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=Tunisys_Dab
